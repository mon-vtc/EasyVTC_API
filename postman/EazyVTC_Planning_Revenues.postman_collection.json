            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.period).to.equal('month');",
            "  const from = new Date(data.date_from);",
            "  pm.expect(from.getUTCDate()).to.equal(1, 'date_from doit être le 1er du mois');",
            "  console.log('Mois:', data.date_from?.slice(0,7), '| courses:', data.total);",
            "});"
          ]}}]
        },
        {
          "name": "[Driver] GET planning — mois spécifique (2026-05-01)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/planning?period=month&date=2026-05-01",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "planning"],
              "query": [
                { "key": "period", "value": "month" },
                { "key": "date",   "value": "2026-05-01" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Mois de mai 2026', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.date_from).to.include('2026-05-01');",
            "  pm.expect(data.date_to).to.include('2026-05-31');",
            "  console.log('Mai 2026 | courses:', data.total);",
            "});"
          ]}}]
        },
        {
          "name": "[400] period invalide",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/planning?period=day",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "planning"],
              "query": [{ "key": "period", "value": "day" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — period invalide', () => pm.response.to.have.status(400));",
            "pm.test('ok = false', () => pm.expect(pm.response.json().ok).to.be.false);",
            "pm.test('Erreur sur le champ period', () => {",
            "  const body = pm.response.json();",
            "  pm.expect(body.errors?.period ?? body.message).to.exist;",
            "});"
          ]}}]
        },
        {
          "name": "[400] date format invalide",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/planning?period=week&date=09-06-2026",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "planning"],
              "query": [
                { "key": "period", "value": "week" },
                { "key": "date",   "value": "09-06-2026" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — format date invalide (doit être YYYY-MM-DD)', () => pm.response.to.have.status(400));",
            "pm.test('ok = false', () => pm.expect(pm.response.json().ok).to.be.false);"
          ]}}]
        }
      ]
    },

    {
      "name": "💰 Chauffeur — Revenus (self)",
      "description": "GET /drivers/me/revenues\nLe chauffeur consulte ses revenus sur les courses terminées (status = completed).\nprice_adjusted écrase price_final si un ajustement admin existe.\nLes montants XOF (Sénégal) et EUR (France) sont agrégés séparément dans revenue_by_currency.",
      "item": [
        {
          "name": "[Driver] GET revenus — mois courant (défaut)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/revenues",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "revenues"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Structure revenus correcte', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.period).to.equal('month');",
            "  pm.expect(data.total_trips).to.be.a('number');",
            "  pm.expect(data.total_revenue).to.be.a('number');",
            "  pm.expect(data.currency).to.be.oneOf(['EUR', 'XOF']);",
            "  pm.expect(data.revenue_by_currency).to.be.an('object');",
            "  pm.expect(data.revenue_by_currency.EUR).to.be.a('number');",
            "  pm.expect(data.revenue_by_currency.XOF).to.be.a('number');",
            "  pm.expect(data.trips).to.be.an('array');",
            "  pm.expect(data.trips.length).to.equal(data.total_trips);",
            "  console.log('Mois courant | courses complétées:', data.total_trips, '| CA EUR:', data.revenue_by_currency.EUR, '| CA XOF:', data.revenue_by_currency.XOF);",
            "});",
            "pm.test('date_from est le 1er du mois', () => {",
            "  const { data } = pm.response.json();",
            "  if (data.date_from) {",
            "    const d = new Date(data.date_from);",
            "    pm.expect(d.getUTCDate()).to.equal(1);",
            "  }",
            "});",
            "pm.test('Chaque trip a les champs attendus', () => {",
            "  const { data } = pm.response.json();",
            "  if (data.trips.length > 0) {",
            "    const t = data.trips[0];",
            "    ['reservation_id','scheduled_at','pickup_address','dest_address','price_final','currency'].forEach(k => {",
            "      pm.expect(t, `champ manquant: ${k}`).to.have.property(k);",
            "    });",
            "    pm.expect(t.currency).to.be.oneOf(['EUR', 'XOF']);",
            "    pm.expect(t.price_final).to.be.a('number');",
            "    pm.expect(t.price_final).to.be.at.least(0);",
            "  }",
            "});",
            "pm.test('total_revenue >= 0', () => {",
            "  const { data } = pm.response.json();",
            "  pm.expect(data.total_revenue).to.be.at.least(0);",
            "  pm.expect(data.revenue_by_currency.EUR).to.be.at.least(0);",
            "  pm.expect(data.revenue_by_currency.XOF).to.be.at.least(0);",
            "});"
          ]}}]
        },
        {
          "name": "[Driver] GET revenus — semaine spécifique",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/revenues?period=week&date=2026-06-09",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "revenues"],
              "query": [
                { "key": "period", "value": "week" },
                { "key": "date",   "value": "2026-06-09" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Période semaine 8→14 juin 2026', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.period).to.equal('week');",
            "  pm.expect(data.date_from).to.include('2026-06-08');",
            "  pm.expect(data.date_to).to.include('2026-06-14');",
            "  console.log('Semaine 8–14 juin | CA EUR:', data.revenue_by_currency.EUR, '| CA XOF:', data.revenue_by_currency.XOF);",
            "});"
          ]}}]
        },
        {
          "name": "[Driver] GET revenus — mois passé (2026-05-01)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/revenues?period=month&date=2026-05-01",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "revenues"],
              "query": [
                { "key": "period", "value": "month" },
                { "key": "date",   "value": "2026-05-01" }
              ]
