            "  console.log('Semaine:', data.date_from?.slice(0,10), '→', data.date_to?.slice(0,10));",
            "});"
          ]}}]
        },
        {
          "name": "[Driver] GET planning — mois courant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/planning?period=month",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "planning"],
              "query": [{ "key": "period", "value": "month" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
