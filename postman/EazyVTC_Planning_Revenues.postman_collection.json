          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Mois de mai 2026', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.date_from).to.include('2026-05-01');",
            "  pm.expect(data.date_to).to.include('2026-05-31');",
            "  console.log('Mai 2026 | courses:', data.total_trips, '| CA:', data.total_revenue, data.currency);",
            "});"
          ]}}]
        },
        {
          "name": "[Driver] GET revenus — tout (period=all, sans filtre de date)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/drivers/me/revenues?period=all",
              "host": ["{{base_url}}"], "path": ["drivers", "me", "revenues"],
              "query": [{ "key": "period", "value": "all" }]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('period=all → date_from et date_to null', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.period).to.equal('all');",
