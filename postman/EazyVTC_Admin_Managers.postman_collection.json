            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/users/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"], "path": ["admin","users","00000000-0000-0000-0000-000000000000"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));",
            "pm.test('ok: false', () => pm.expect(pm.response.json().ok).to.be.false);"
          ]}}]
        }
      ]
    },

    {
