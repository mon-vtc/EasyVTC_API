        {
          "name": "Confirmer : structure complète d'un AvailableDriverDto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data;",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ok: true',   () => pm.expect(pm.response.json().ok).to.be.true);",
                  "",
                  "pm.test('Chaque driver a les champs requis (AvailableDriverDto)', () => {",
                  "  data.forEach(d => {",
                  "    pm.expect(d, `driver ${d.id}`).to.have.all.keys('id', 'rating', 'is_online', 'status', 'vehicle_type', 'zone', 'user', 'vehicle');",
                  "  });",
                  "});",
                  "",
                  "pm.test('Chaque user a les champs requis', () => {",
                  "  data.forEach(d => {",
                  "    pm.expect(d.user, `user du driver ${d.id}`).to.have.all.keys('id', 'first_name', 'last_name', 'email', 'phone', 'profile_photo_url');",
                  "  });",
                  "});",
                  "",
                  "pm.test('Chaque véhicule actif a les champs requis', () => {",
                  "  data.filter(d => d.vehicle !== null).forEach(d => {",
                  "    pm.expect(d.vehicle, `vehicle du driver ${d.id}`).to.have.all.keys('id', 'model', 'plate_number', 'brand', 'color', 'type', 'photo_url');",
                  "  });",
                  "});",
                  "",
                  "pm.test('vehicle.type cohérent avec driver.vehicle_type', () => {",
                  "  data.filter(d => d.vehicle !== null).forEach(d => {",
                  "    pm.expect(d.vehicle.type, `incohérence pour ${d.id}`).to.equal(d.vehicle_type);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
