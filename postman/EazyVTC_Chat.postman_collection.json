                "pm.test('sender_role = admin', () => {",
                "  const { ok, data } = pm.response.json();",
                "  pm.expect(ok).to.be.true;",
                "  pm.expect(data.sender_role).to.equal('admin');",
                "});"
              ]
            }
          }]
        }

      ]
    },

    {
      "name": "👨‍💼 Admin — Vue toutes les conversations",
      "description": "GET /admin/chat — Accessible uniquement admin et manager. Retourne toutes les réservations actives avec dernier message et nb non-lus.",
      "item": [

        {
          "name": "[Admin] GET /admin/chat — liste paginée",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/chat?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["admin", "chat"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Structure paginée correcte', () => {",
                "  const { ok, data } = pm.response.json();",
                "  pm.expect(ok).to.be.true;",
                "  pm.expect(data).to.have.property('conversations').that.is.an('array');",
                "  pm.expect(data).to.have.property('total').that.is.a('number');",
                "  pm.expect(data).to.have.property('page').that.equal(1);",
                "  pm.expect(data).to.have.property('limit').that.equal(10);",
                "  pm.expect(data).to.have.property('total_pages');",
                "});",
                "pm.test('Chaque conversation a les champs attendus', () => {",
                "  const { data } = pm.response.json();",
                "  if (data.conversations.length > 0) {",
                "    const conv = data.conversations[0];",
                "    pm.expect(conv).to.have.property('reservation_id');",
                "    pm.expect(conv).to.have.property('pickup_address');",
                "    pm.expect(conv).to.have.property('dest_address');",
                "    pm.expect(conv).to.have.property('last_message');",
                "    pm.expect(conv).to.have.property('last_message_at');",
                "    pm.expect(conv).to.have.property('unread_count').that.is.a('number');",
                "    pm.expect(conv).to.have.property('client');",
                "    pm.expect(conv).to.have.property('driver');",
                "  }",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[Admin] GET /admin/chat — page 2",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/chat?page=2&limit=5",
              "host": ["{{base_url}}"],
              "path": ["admin", "chat"],
              "query": [
                { "key": "page",  "value": "2" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('page = 2 dans la réponse', () => {",
                "  const { data } = pm.response.json();",
                "  pm.expect(data.page).to.equal(2);",
                "  pm.expect(data.limit).to.equal(5);",
                "});"
              ]
            }
          }]
        }

      ]
    },

