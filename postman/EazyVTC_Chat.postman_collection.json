          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/reservations/{{reservation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "reservations", "{{reservation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}{{$randomLoremParagraphs}}\"\n}"
            }
          },
          "event": [{
            "listen": "prerequest",
            "script": {
              "exec": [
                "// Générer un contenu de 2001 caractères",
                "pm.collectionVariables.set('long_content', 'A'.repeat(2001));"
              ]
            }
          }, {
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 — message trop long', () => pm.response.to.have.status(400));",
                "pm.test('ok = false', () => {",
                "  const { ok } = pm.response.json();",
                "  pm.expect(ok).to.be.false;",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[400] reservationId invalide (pas un UUID)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/chat/reservations/not-a-valid-uuid/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "reservations", "not-a-valid-uuid", "messages"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 — UUID invalide', () => pm.response.to.have.status(400));",
                "pm.test('ok = false', () => {",
                "  const { ok } = pm.response.json();",
                "  pm.expect(ok).to.be.false;",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[404] Réservation inexistante",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/chat/reservations/00000000-0000-0000-0000-000000000000/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "reservations", "00000000-0000-0000-0000-000000000000", "messages"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403 ou 404 — réservation inconnue', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([403, 404]);",
                "});",
                "pm.test('ok = false', () => {",
                "  const { ok } = pm.response.json();",
                "  pm.expect(ok).to.be.false;",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[400] Body manquant (POST sans content)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/reservations/{{reservation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "reservations", "{{reservation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 — body invalide', () => pm.response.to.have.status(400));",
                "pm.test('Erreurs de champs présentes', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.ok).to.be.false;",
                "  pm.expect(body.errors ?? body.message).to.exist;",
                "});"
              ]
            }
          }]
        }

      ]
    }

  ]
}
