    {
      "name": "Client : Historique des messages",
      "item": [
        {
          "name": "[Client] GET historique : page 1 défaut",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Structure paginée correcte', () => {",
                  "  const { ok, data } = pm.response.json();",
                  "  pm.expect(ok).to.be.true;",
                  "  pm.expect(data.messages).to.be.an('array');",
                  "  pm.expect(data.total).to.be.a('number');",
                  "  pm.expect(data.page).to.equal(1);",
                  "  pm.expect(data.limit).to.equal(50);",
                  "  pm.expect(data.total_pages).to.be.a('number');",
                  "});",
                  "pm.test('Messages triés ASC par created_at', () => {",
                  "  const { data } = pm.response.json();",
                  "  if (data.messages.length >= 2) {",
                  "    const t1 = new Date(data.messages[0].created_at).getTime();",
                  "    const t2 = new Date(data.messages[1].created_at).getTime();",
                  "    pm.expect(t1).to.be.at.most(t2);",
                  "  }",
                  "});",
                  "pm.test('Chaque message a tous les champs', () => {",
                  "  const { data } = pm.response.json();",
                  "  if (data.messages.length > 0) {",
                  "    const msg = data.messages[0];",
                  "    ['id','reservation_id','sender_id','sender_role','content','read_at','created_at'].forEach(k => {",
                  "      pm.expect(msg).to.have.property(k);",
                  "    });",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
