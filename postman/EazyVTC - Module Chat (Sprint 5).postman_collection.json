    {
      "name": "Setup : Réservation test",
      "item": [
        {
          "name": "Get mes réservations assigned (client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('reservation_id sauvegardé', () => {",
                  "  const { ok, data } = pm.response.json();",
                  "  pm.expect(ok).to.be.true;",
                  "  const list = data.reservations ?? data.data ?? data;",
                  "  if (Array.isArray(list) && list.length > 0) {",
                  "    pm.collectionVariables.set('reservation_id', list[0].id);",
                  "    console.log('reservation_id:', list[0].id);",
                  "  } else {",
                  "    console.warn('Aucune réservation assigned — saisir reservation_id manuellement dans les variables');",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{client_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/reservations?status=assigned&limit=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reservations"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "assigned"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Trouver une réservation assigned appartenant au client. Sauvegarde reservation_id."
    },
