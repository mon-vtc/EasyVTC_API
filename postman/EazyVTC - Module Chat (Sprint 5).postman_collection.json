          "name": "[Client] POST message : OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('ChatMessage retourné', () => {",
                  "  const { ok, data } = pm.response.json();",
                  "  pm.expect(ok).to.be.true;",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('reservation_id');",
                  "  pm.expect(data).to.have.property('sender_id');",
                  "  pm.expect(data.sender_role).to.equal('client');",
                  "  pm.expect(data.content).to.equal('Bonjour, je serai en bas dans 5 minutes.');",
                  "  pm.expect(data.read_at).to.be.null;",
                  "  pm.expect(data).to.have.property('created_at');",
                  "  pm.collectionVariables.set('message_id', data.id);",
                  "  console.log('message_id:', data.id);",
                  "});"
