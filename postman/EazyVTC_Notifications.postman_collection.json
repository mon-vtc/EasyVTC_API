            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["notifications", "{{notification_id}}", "read"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 — idempotent (déjà lue = OK quand même)', () => pm.response.to.have.status(200));",
                "pm.test('ok: true même si déjà lu', () => {",
                "  const { ok } = pm.response.json();",
                "  pm.expect(ok).to.be.true;",
                "  console.log(' Idempotence markAsRead : 2ème appel = 200 OK');",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[Client] Marquer tout comme lu",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/notifications/read-all",
              "host": ["{{base_url}}"],
              "path": ["notifications", "read-all"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Compteur mis à jour retourné', () => {",
                "  const { ok, data, message } = pm.response.json();",
                "  pm.expect(ok).to.be.true;",
                "  pm.expect(data.updated).to.be.a('number');",
                "  pm.expect(data.updated).to.be.at.least(0);",
                "  console.log(message);",
                "  console.log('   Notifications marquées lues:', data.updated);",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[Client] Marquer tout — idempotence (déjà toutes lues)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/notifications/read-all",
              "host": ["{{base_url}}"],
              "path": ["notifications", "read-all"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 — 0 notifications mises à jour (déjà toutes lues)', () => pm.response.to.have.status(200));",
                "pm.test('updated = 0 si rien à marquer', () => {",
                "  const { data } = pm.response.json();",
                "  pm.expect(data.updated).to.equal(0);",
                "  console.log(' Idempotence read-all : 0 nouvelles mises à jour');",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[400] Marquer comme lu — ID non-UUID",
          "request": {
