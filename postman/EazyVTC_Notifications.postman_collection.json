    {
      "name": "✅ Marquer comme lu",
      "description": "PATCH /notifications/:id/read et PATCH /notifications/read-all. Requiert notification_id sauvegardé.",
      "item": [

        {
          "name": "[Client] Marquer une notification comme lue",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{client_token}}" }],
            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}/read",
