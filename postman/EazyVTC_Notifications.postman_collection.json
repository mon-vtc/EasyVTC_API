              ]
            }
          }]
        },

        {
          "name": "[403/404] Driver essaie de lire une notif du client",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{driver_token}}" }],
            "url": {
              "raw": "{{base_url}}/notifications/{{notification_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["notifications", "{{notification_id}}", "read"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 403 ou 404 — isolation inter-utilisateurs', () => {",
                "  pm.expect([403, 404]).to.include(pm.response.code);",
                "  console.log(' Status:', pm.response.code, '— notification appartenant à un autre user');",
                "});",
                "pm.test('ok: false', () => pm.expect(pm.response.json().ok).to.be.false);"
              ]
            }
          }]
        }

      ]
    },

