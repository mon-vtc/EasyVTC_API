              "path": ["notifications", "{{notification_id}}", "read"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Notification marquée comme lue', () => {",
                "  const { ok, message } = pm.response.json();",
                "  pm.expect(ok).to.be.true;",
                "  pm.expect(message).to.include('lue');",
                "  console.log(' Notification', pm.collectionVariables.get('notification_id'), 'marquée comme lue');",
                "});"
              ]
            }
          }]
        },

        {
          "name": "[Client] Marquer une notification lue — idempotence",
          "request": {
            "method": "PATCH",
