    {
      "name": "🎟️ Client — Valider un code avant réservation",
      "item": [
        {
          "name": "POST /promo-codes/validate — code valide (BIENVENUE10 → 15%)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/promo-codes/validate", "host": ["{{base_url}}"], "path": ["promo-codes","validate"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"BIENVENUE10\",\n  \"order_amount\": 80\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Remise calculée correctement', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  pm.expect(data.code).to.equal('BIENVENUE10');",
            "  pm.expect(data.discount_type).to.equal('percent');",
            "  pm.expect(data.discount_value).to.equal(15);",
            "  pm.expect(data.discount_amount).to.be.a('number').and.above(0);",
            "  pm.expect(data.final_price).to.be.a('number').and.below(80);",
            "  pm.expect(data.final_price).to.be.closeTo(80 - data.discount_amount, 0.01);",
            "  console.log('Montant initial: 80 | Remise:', data.discount_amount, '| Prix final:', data.final_price);",
            "});"
          ]}}]
        },
        {
          "name": "POST /promo-codes/validate — montant sous min_order_amount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/promo-codes/validate", "host": ["{{base_url}}"], "path": ["promo-codes","validate"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"BIENVENUE10\",\n  \"order_amount\": 10\n}" }
          },
