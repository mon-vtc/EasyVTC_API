            "pm.test('ok = false', () => pm.expect(pm.response.json().ok).to.be.false);",
            "console.log('Message:', pm.response.json().message);"
          ]}}]
        },
        {
          "name": "[422] POST — code inexistant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/promo-codes/validate", "host": ["{{base_url}}"], "path": ["promo-codes","validate"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"CODEINVALIDE\",\n  \"order_amount\": 80\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404 ou 422 — code introuvable ou inactif', () => {",
            "  pm.expect(pm.response.code).to.be.oneOf([404, 422]);",
            "});",
            "pm.test('ok = false', () => pm.expect(pm.response.json().ok).to.be.false);"
          ]}}]
        }
      ]
    },

