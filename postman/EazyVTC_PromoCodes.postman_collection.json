              { "key": "Authorization", "value": "Bearer {{driver_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/promo-codes/validate", "host": ["{{base_url}}"], "path": ["promo-codes","validate"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"BIENVENUE10\",\n  \"order_amount\": 80\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 403 — réservé aux clients', () => pm.response.to.have.status(403));"
          ]}}]
        }
      ]
    }

  ]
}
