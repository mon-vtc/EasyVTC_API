          ]}}]
        },
        {
          "name": "③ GET /admin/promo-codes/:id — détail BIENVENUE10",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/promo-codes/{{promo_id_percent}}",
              "host": ["{{base_url}}"], "path": ["admin","promo-codes","{{promo_id_percent}}"]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Champs requis présents', () => {",
            "  const { ok, data } = pm.response.json();",
            "  pm.expect(ok).to.be.true;",
            "  ['id','code','discount_type','discount_value','is_active','uses_count','created_at'].forEach(k => {",
            "    pm.expect(data, `champ manquant: ${k}`).to.have.property(k);",
            "  });",
            "  pm.expect(data.id).to.equal(pm.collectionVariables.get('promo_id_percent'));",
            "  console.log('Code:', data.code, '| utilisations:', data.uses_count, '/', data.max_uses ?? '∞');",
            "});"
          ]}}]
        },
        {
