            "body": { "mode": "raw", "raw": "{\n  \"code\": \"BIENVENUE10\",\n  \"discount_type\": \"percent\",\n  \"discount_value\": 10,\n  \"valid_from\": \"2026-01-01T00:00:00.000Z\",\n  \"valid_until\": \"2026-12-31T23:59:59.000Z\",\n  \"max_uses\": null,\n  \"min_order_amount\": 20\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
