PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
MOBILE_DEEP_LINK_SCHEME=easyvtc

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé service role (recommandée, nouvelle génération Supabase)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé legacy si ton projet utilise encore l'ancien format
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE

# Clé publique (front-end)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE

MAIL_MAILER=smtp
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your-mailtrap-inbox-user
MAILTRAP_PASS=your-mailtrap-inbox-password
MAIL_FROM=contact@easyvtc.com

# SendGrid (production uniquement — remplace Mailtrap)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret cron — générer avec : openssl rand -base64 32
# Obligatoire en production (min 32 caractères)
CRON_SECRET=changez-moi-avec-openssl-rand-base64-32

# Firebase Admin SDK (push notifications FCM v1)
# Valeurs extraites depuis Firebase Console > Project Settings > Service Accounts
# (Generate new private key — NE JAMAIS committer le fichier JSON)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"
